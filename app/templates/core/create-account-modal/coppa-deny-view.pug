form.modal-body.coppa-deny
  .modal-body-content
    .individual-flow-panel
      .individual-flow-progress(aria-hidden="true")
        .individual-flow-progress-step.active
        .individual-flow-progress-step
      .individual-flow-card.parent-email-card
        if !view.state.get('parentEmailSent')
          .individual-flow-heading
            h4(data-i18n="signup.parent_email_header")
          .form-group.parent-email-input-group
            label.sr-only(for="parent-email-input" data-i18n="signup.parent_email_label")
            input#parent-email-input.form-control.input-lg(type="email" name="parentEmail" placeholder="parent@email.com" value=state.get('parentEmail'))
          if state.get('error')
            p.small.error
              span(data-i18n="signup.parent_email_error")
          if state.get('dontUseOurEmailSilly')
            p.error
              span(data-i18n="signup.dont_use_our_email_silly")
          .parent-email-blurb.render
        else
          .parent-email-confirmation
            .parent-email-confirmation-mark
              span.glyphicon.glyphicon-ok
            .individual-flow-heading
              h4(data-i18n="signup.parent_email_check_inbox")
            p.parent-email-sent-copy
              span(data-i18n="signup.parent_email_sent")
            p.parent-email-blurb(data-i18n="signup.parent_email_finish_blurb")

  .history-nav-buttons.individual
    if !state.get('parentEmailSent')
      button.send-parent-email-button.btn.btn-lg.btn-navy(type='submit', disabled=state.get('parentEmailSending') || state.get('dontUseOurEmailSilly'))
        if state.get('parentEmailSending')
          span(data-i18n="common.sending")
        else
          span(data-i18n="signup.send_to_parent")
      button.back-btn.btn.btn-lg.btn-navy-alt(type='button')
        span(data-i18n="common.back")
    else
      a.play-without-saving-button.btn.btn-lg.btn-navy(href="/play" data-dismiss="modal" data-i18n="signup.play_without_saving")
